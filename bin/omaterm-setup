#!/usr/bin/env bash
set -euo pipefail

MARKER="$HOME/.omaterm-setup-done"

case "${1:-}" in
  --rerun|--force)
    rm -f "$MARKER"
    shift
    ;;
  --reset)
    rm -f "$MARKER"
    echo "Omaterm setup marker removed."
    exit 0
    ;;
  --help|-h)
    cat <<'EOF'
Usage: omaterm-setup [--rerun|--force|--reset]

Runs the first-time Omaterm setup, then starts zsh.

Options:
  --rerun, --force  Remove the setup marker and run setup now.
  --reset           Remove the setup marker and exit.
EOF
    exit 0
    ;;
esac

if [ -f "$MARKER" ]; then
  exec bash -l "$@"
fi

prompt_value() {
  local label="$1"
  local default="${2:-}"
  local value

  if [ -n "$default" ]; then
    printf "%s [%s]: " "$label" "$default" > /dev/tty
  else
    printf "%s: " "$label" > /dev/tty
  fi

  IFS= read -r value < /dev/tty
  echo "${value:-$default}"
}

configure_git_identity() {
  local name email

  name="$(git config --global user.name 2>/dev/null || true)"
  email="$(git config --global user.email 2>/dev/null || true)"

  name="$(prompt_value "Git user name" "$name")"
  email="$(prompt_value "Git email" "$email")"

  if [ -z "$name" ] || [ -z "$email" ]; then
    echo "Skipping Git identity; name and email are both required."
    return
  fi

  git config --file "$HOME/.gitconfig" user.name "$name"
  git config --file "$HOME/.gitconfig" user.email "$email"
}

echo
echo " ▄██████▄    ▄▄▄▄███▄▄▄▄      ▄████████     ███        ▄████████    ▄████████   ▄▄▄▄███▄▄▄▄
███    ███ ▄██▀▀▀███▀▀▀██▄   ███    ███ ▀█████████▄   ███    ███   ███    ███ ▄██▀▀▀███▀▀▀██▄
███    ███ ███   ███   ███   ███    ███    ▀███▀▀██   ███    █▀    ███    ███ ███   ███   ███
███    ███ ███   ███   ███   ███    ███     ███   ▀  ▄███▄▄▄      ▄███▄▄▄▄██▀ ███   ███   ███
███    ███ ███   ███   ███ ▀███████████     ███     ▀▀███▀▀▀     ▀▀███▀▀▀▀▀   ███   ███   ███
███    ███ ███   ███   ███   ███    ███     ███       ███    █▄  ▀███████████ ███   ███   ███
███    ███ ███   ███   ███   ███    ███     ███       ███    ███   ███    ███ ███   ███   ███
 ▀██████▀   ▀█   ███   █▀    ███    █▀     ▄████▀     ██████████   ███    ███  ▀█   ███   █▀
                                                                   ███    ███                "
echo
echo "Welcome to Omaterm! Let's get you set up."
echo

# Git identity
if ! git config --global user.name &>/dev/null || ! git config --global user.email &>/dev/null; then
  if gum confirm "Identify for Git?"; then
    configure_git_identity
  fi
fi

# GitHub CLI
if ! gh auth status &>/dev/null; then
  echo
  if gum confirm "Authenticate with GitHub?"; then
    gh auth login
  fi
fi

# Tailscale
if command -v tailscale &>/dev/null && ! tailscale status &>/dev/null; then
  echo
  if gum confirm "Connect to Tailscale?"; then
    if [ ! -f /etc/NIXOS ]; then
      sudo tailscaled &>/dev/null &
    fi
    sudo tailscale up --ssh --accept-routes
  fi
fi

echo
echo "✓ Setup complete!"
touch "$MARKER"
exec bash -l "$@"
